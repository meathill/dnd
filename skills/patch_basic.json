{
  "name": "patch_basic",
  "version": 1,
  "title": "修改模组基础信息",
  "description": "修改模组的标题、简介、背景设定与难度，只返回结构化 patch 建议。",
  "group": "module",
  "executionMode": "native",
  "whenToUse": [
    "用户要求调整模组标题、简介、设定或难度时。",
    "需要把散乱描述整理为基础信息时。"
  ],
  "forbidden": [
    "没有明确修改字段时瞎补内容。"
  ],
  "inputSchema": {
    "type": "object",
    "properties": {
      "title": {
        "type": "string",
        "description": "模组标题。"
      },
      "summary": {
        "type": "string",
        "description": "模组简介。"
      },
      "setting": {
        "type": "string",
        "description": "背景设定。"
      },
      "difficulty": {
        "type": "string",
        "description": "难度描述。"
      }
    },
    "required": [],
    "description": "模组基础信息 patch 参数。",
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "kind": {
        "type": "string",
        "const": "module_patch",
        "description": "结果类型。"
      },
      "action": {
        "type": "string",
        "enum": [
          "patch_basic",
          "patch_background",
          "patch_npc",
          "remove_npc",
          "patch_scene",
          "remove_scene",
          "patch_options"
        ],
        "description": "patch 动作。"
      },
      "targetType": {
        "type": "string",
        "enum": [
          "script",
          "background",
          "npc",
          "scene",
          "options"
        ],
        "description": "修改目标类型。"
      },
      "targetId": {
        "type": [
          "string",
          "null"
        ],
        "description": "目标 id；新增时可为空。"
      },
      "mode": {
        "type": "string",
        "enum": [
          "create",
          "update",
          "remove"
        ],
        "description": "修改模式。"
      },
      "changedFields": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "被修改字段。"
        },
        "description": "变更字段列表。"
      },
      "patch": {
        "type": "object",
        "description": "结构化对象，由宿主根据上下文继续消费。",
        "additionalProperties": true
      },
      "summary": {
        "type": "string",
        "description": "中文摘要。"
      }
    },
    "required": [
      "kind",
      "action",
      "targetType",
      "mode",
      "changedFields",
      "patch",
      "summary"
    ],
    "description": "模组基础信息 patch。",
    "additionalProperties": false
  }
}
