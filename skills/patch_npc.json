{
  "name": "patch_npc",
  "version": 1,
  "title": "新增或修改 NPC",
  "description": "新增或更新一个 NPC，只返回结构化 patch 建议。",
  "group": "module",
  "executionMode": "native",
  "whenToUse": [
    "用户要求补充、修改关键 NPC 时。",
    "需要把 NPC 设定整理为结构化档案时。"
  ],
  "forbidden": [
    "更新现有 NPC 时编造不存在的 id。"
  ],
  "inputSchema": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "description": "已有 NPC 的 id；新增时可省略。"
      },
      "name": {
        "type": "string",
        "description": "NPC 名称。"
      },
      "type": {
        "type": "string",
        "description": "NPC 类别。"
      },
      "role": {
        "type": "string",
        "enum": [
          "ally",
          "neutral",
          "enemy"
        ],
        "description": "与玩家的关系。"
      },
      "threat": {
        "type": "string",
        "description": "威胁等级。"
      },
      "summary": {
        "type": "string",
        "description": "NPC 简介。"
      },
      "useWhen": {
        "type": "string",
        "description": "登场时机。"
      },
      "status": {
        "type": "string",
        "description": "当前状态。"
      },
      "hp": {
        "type": "number",
        "description": "生命值。"
      },
      "armor": {
        "type": "number",
        "description": "护甲。"
      },
      "move": {
        "type": "number",
        "description": "移动。"
      },
      "traits": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "特性。"
        },
        "description": "特性列表。"
      },
      "tactics": {
        "type": "string",
        "description": "战术。"
      },
      "weakness": {
        "type": "string",
        "description": "弱点。"
      },
      "sanityLoss": {
        "type": "string",
        "description": "理智损失。"
      }
    },
    "required": [],
    "description": "NPC patch 参数。",
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "kind": {
        "type": "string",
        "const": "module_patch",
        "description": "结果类型。"
      },
      "action": {
        "type": "string",
        "enum": [
          "patch_basic",
          "patch_background",
          "patch_npc",
          "remove_npc",
          "patch_scene",
          "remove_scene",
          "patch_options"
        ],
        "description": "patch 动作。"
      },
      "targetType": {
        "type": "string",
        "enum": [
          "script",
          "background",
          "npc",
          "scene",
          "options"
        ],
        "description": "修改目标类型。"
      },
      "targetId": {
        "type": [
          "string",
          "null"
        ],
        "description": "目标 id；新增时可为空。"
      },
      "mode": {
        "type": "string",
        "enum": [
          "create",
          "update",
          "remove"
        ],
        "description": "修改模式。"
      },
      "changedFields": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "被修改字段。"
        },
        "description": "变更字段列表。"
      },
      "patch": {
        "type": "object",
        "description": "结构化对象，由宿主根据上下文继续消费。",
        "additionalProperties": true
      },
      "summary": {
        "type": "string",
        "description": "中文摘要。"
      }
    },
    "required": [
      "kind",
      "action",
      "targetType",
      "mode",
      "changedFields",
      "patch",
      "summary"
    ],
    "description": "NPC patch。",
    "additionalProperties": false
  }
}
