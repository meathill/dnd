{
  "name": "select_ruleset",
  "version": 1,
  "title": "选择规则系统",
  "description": "列出当前可用规则系统，默认返回 coc-7e-lite。",
  "group": "rulebook",
  "executionMode": "native",
  "whenToUse": [
    "开始制作模组前确认当前规则系统。",
    "用户未明确说明规则系统时回到 COC 默认值。"
  ],
  "forbidden": [
    "把模组特例误当作规则书默认规则。"
  ],
  "inputSchema": {
    "type": "object",
    "properties": {},
    "required": [],
    "description": "无需参数。",
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "rulesets": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "规则系统 id。"
            },
            "name": {
              "type": "string",
              "description": "规则系统名称。"
            },
            "summary": {
              "type": "string",
              "description": "规则系统简介。"
            }
          },
          "required": [
            "id",
            "name",
            "summary"
          ],
          "description": "规则系统摘要。",
          "additionalProperties": false
        },
        "description": "规则系统列表。"
      },
      "defaultRulesetId": {
        "type": "string",
        "description": "默认规则系统 id。"
      }
    },
    "required": [
      "rulesets",
      "defaultRulesetId"
    ],
    "description": "规则系统选择结果。",
    "additionalProperties": false
  }
}
