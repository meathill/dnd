{
  "name": "get_creature_profile",
  "version": 1,
  "title": "读取怪物模板",
  "description": "读取规则书中的怪物或超自然威胁模板。",
  "group": "rulebook",
  "executionMode": "native",
  "whenToUse": [
    "需要怪物/威胁模板时。",
    "评估超自然场景的战斗和理智压力时。"
  ],
  "forbidden": [
    "不查档案就自由发挥关键规则实体。"
  ],
  "inputSchema": {
    "type": "object",
    "properties": {
      "rulesetId": {
        "type": "string",
        "description": "规则系统 id，可留空。"
      },
      "entityId": {
        "type": "string",
        "description": "规则书实体 id。"
      }
    },
    "required": [
      "entityId"
    ],
    "description": "规则书实体读取参数。",
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "item": {
        "type": [
          "object",
          "null"
        ],
        "properties": {
          "rulesetId": {
            "type": "string",
            "description": "规则系统 id。"
          },
          "type": {
            "type": "string",
            "enum": [
              "rule",
              "skill",
              "occupation_template",
              "npc_template",
              "creature",
              "hazard",
              "sanity_loss",
              "scene_risk_guideline"
            ],
            "description": "规则书实体类型。"
          },
          "id": {
            "type": "string",
            "description": "实体 id。"
          },
          "name": {
            "type": "string",
            "description": "实体名称。"
          },
          "summary": {
            "type": "string",
            "description": "实体摘要。"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "标签。"
            },
            "description": "标签列表。"
          },
          "source": {
            "type": "string",
            "description": "来源标记。"
          },
          "data": {
            "type": "object",
            "description": "结构化对象，由宿主根据上下文继续消费。",
            "additionalProperties": true
          }
        },
        "required": [
          "rulesetId",
          "type",
          "id",
          "name",
          "summary",
          "tags",
          "source",
          "data"
        ],
        "description": "命中的规则书实体；若未命中则为 null。",
        "additionalProperties": false
      }
    },
    "required": [
      "item"
    ],
    "description": "规则书实体读取结果。",
    "additionalProperties": false
  }
}
