{
  "name": "patch_scene",
  "version": 1,
  "title": "新增或修改场景",
  "description": "新增或更新一个场景，只返回结构化 patch 建议。",
  "group": "module",
  "executionMode": "native",
  "whenToUse": [
    "用户要求补场景、重写场景或调整线索钩子时。"
  ],
  "forbidden": [
    "更新现有场景时编造不存在的 id。"
  ],
  "inputSchema": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "description": "已有场景 id；新增时可省略。"
      },
      "title": {
        "type": "string",
        "description": "场景标题。"
      },
      "summary": {
        "type": "string",
        "description": "场景简介。"
      },
      "location": {
        "type": "string",
        "description": "场景地点。"
      },
      "hooks": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "引导钩子。"
        },
        "description": "引导钩子列表。"
      }
    },
    "required": [],
    "description": "场景 patch 参数。",
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "kind": {
        "type": "string",
        "const": "module_patch",
        "description": "结果类型。"
      },
      "action": {
        "type": "string",
        "enum": [
          "patch_basic",
          "patch_background",
          "patch_npc",
          "remove_npc",
          "patch_scene",
          "remove_scene",
          "patch_options"
        ],
        "description": "patch 动作。"
      },
      "targetType": {
        "type": "string",
        "enum": [
          "script",
          "background",
          "npc",
          "scene",
          "options"
        ],
        "description": "修改目标类型。"
      },
      "targetId": {
        "type": [
          "string",
          "null"
        ],
        "description": "目标 id；新增时可为空。"
      },
      "mode": {
        "type": "string",
        "enum": [
          "create",
          "update",
          "remove"
        ],
        "description": "修改模式。"
      },
      "changedFields": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "被修改字段。"
        },
        "description": "变更字段列表。"
      },
      "patch": {
        "type": "object",
        "description": "结构化对象，由宿主根据上下文继续消费。",
        "additionalProperties": true
      },
      "summary": {
        "type": "string",
        "description": "中文摘要。"
      }
    },
    "required": [
      "kind",
      "action",
      "targetType",
      "mode",
      "changedFields",
      "patch",
      "summary"
    ],
    "description": "场景 patch。",
    "additionalProperties": false
  }
}
