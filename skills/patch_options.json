{
  "name": "patch_options",
  "version": 1,
  "title": "修改模组选项池",
  "description": "修改模组的装备、出身、buff、debuff 选项池，只返回结构化 patch 建议。",
  "group": "module",
  "executionMode": "native",
  "whenToUse": [
    "用户要求调整可选装备、出身、buff 或 debuff 时。"
  ],
  "forbidden": [
    "把增量 patch 误当成追加，导致列表语义不清。"
  ],
  "inputSchema": {
    "type": "object",
    "properties": {
      "equipmentOptions": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "装备选项。"
        },
        "description": "装备选项列表。"
      },
      "originOptions": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "出身选项。"
        },
        "description": "出身选项列表。"
      },
      "buffOptions": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "buff 选项。"
        },
        "description": "buff 选项列表。"
      },
      "debuffOptions": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "debuff 选项。"
        },
        "description": "debuff 选项列表。"
      }
    },
    "required": [],
    "description": "模组选项池 patch 参数。",
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "kind": {
        "type": "string",
        "const": "module_patch",
        "description": "结果类型。"
      },
      "action": {
        "type": "string",
        "enum": [
          "patch_basic",
          "patch_background",
          "patch_npc",
          "remove_npc",
          "patch_scene",
          "remove_scene",
          "patch_options"
        ],
        "description": "patch 动作。"
      },
      "targetType": {
        "type": "string",
        "enum": [
          "script",
          "background",
          "npc",
          "scene",
          "options"
        ],
        "description": "修改目标类型。"
      },
      "targetId": {
        "type": [
          "string",
          "null"
        ],
        "description": "目标 id；新增时可为空。"
      },
      "mode": {
        "type": "string",
        "enum": [
          "create",
          "update",
          "remove"
        ],
        "description": "修改模式。"
      },
      "changedFields": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "被修改字段。"
        },
        "description": "变更字段列表。"
      },
      "patch": {
        "type": "object",
        "description": "结构化对象，由宿主根据上下文继续消费。",
        "additionalProperties": true
      },
      "summary": {
        "type": "string",
        "description": "中文摘要。"
      }
    },
    "required": [
      "kind",
      "action",
      "targetType",
      "mode",
      "changedFields",
      "patch",
      "summary"
    ],
    "description": "模组选项池 patch。",
    "additionalProperties": false
  }
}
