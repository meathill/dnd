{
  "name": "list_local_artifacts",
  "version": 1,
  "title": "列出本地产物",
  "description": "列出工作区中已经保存的模组、人物卡或战报。",
  "group": "record",
  "executionMode": "native",
  "whenToUse": [
    "需要查看当前工作区已有本地产物时。",
    "在保存前后确认持久化结果时。"
  ],
  "forbidden": [
    "重复生成已存在产物而不先检查。"
  ],
  "inputSchema": {
    "type": "object",
    "properties": {
      "kind": {
        "type": "string",
        "enum": [
          "module",
          "character",
          "report"
        ],
        "description": "要列出的产物类型。"
      }
    },
    "required": [
      "kind"
    ],
    "description": "本地产物列表参数。",
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "module",
                "character",
                "report"
              ],
              "description": "产物类型。"
            },
            "id": {
              "type": "string",
              "description": "产物 id。"
            },
            "title": {
              "type": "string",
              "description": "标题。"
            },
            "updatedAt": {
              "type": "string",
              "description": "更新时间。"
            },
            "filePath": {
              "type": "string",
              "description": "相对文件路径。"
            }
          },
          "required": [
            "kind",
            "id",
            "title",
            "updatedAt",
            "filePath"
          ],
          "description": "本地产物摘要。",
          "additionalProperties": false
        },
        "description": "本地产物列表。"
      }
    },
    "required": [
      "items"
    ],
    "description": "本地产物列表结果。",
    "additionalProperties": false
  }
}
