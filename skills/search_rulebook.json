{
  "name": "search_rulebook",
  "version": 1,
  "title": "搜索规则书实体",
  "description": "搜索 COC 最小规则库中的技能、模板、怪物和规则条目。",
  "group": "rulebook",
  "executionMode": "native",
  "whenToUse": [
    "需要标准技能、职业、怪物或 NPC 模板时。",
    "模组制作中需要确认标准条目而不是自己硬编时。"
  ],
  "forbidden": [
    "规则书已经有标准实体时，重新编造一套不一致的数据。",
    "导入商业规则书全文。"
  ],
  "inputSchema": {
    "type": "object",
    "properties": {
      "rulesetId": {
        "type": "string",
        "description": "规则系统 id，可留空。"
      },
      "query": {
        "type": "string",
        "description": "搜索关键字，可留空。"
      },
      "type": {
        "type": "string",
        "enum": [
          "rule",
          "skill",
          "occupation_template",
          "npc_template",
          "creature",
          "hazard",
          "sanity_loss",
          "scene_risk_guideline"
        ],
        "description": "规则书实体类型。"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string",
          "description": "标签。"
        },
        "description": "标签过滤。"
      },
      "limit": {
        "type": "integer",
        "description": "最大返回数量。",
        "minimum": 1,
        "maximum": 50
      }
    },
    "required": [],
    "description": "规则书搜索参数。",
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "rulesetId": {
              "type": "string",
              "description": "规则系统 id。"
            },
            "type": {
              "type": "string",
              "enum": [
                "rule",
                "skill",
                "occupation_template",
                "npc_template",
                "creature",
                "hazard",
                "sanity_loss",
                "scene_risk_guideline"
              ],
              "description": "规则书实体类型。"
            },
            "id": {
              "type": "string",
              "description": "实体 id。"
            },
            "name": {
              "type": "string",
              "description": "实体名称。"
            },
            "summary": {
              "type": "string",
              "description": "实体摘要。"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string",
                "description": "标签。"
              },
              "description": "标签列表。"
            },
            "source": {
              "type": "string",
              "description": "来源标记。"
            },
            "data": {
              "type": "object",
              "description": "结构化对象，由宿主根据上下文继续消费。",
              "additionalProperties": true
            }
          },
          "required": [
            "rulesetId",
            "type",
            "id",
            "name",
            "summary",
            "tags",
            "source",
            "data"
          ],
          "description": "命中的规则书实体。",
          "additionalProperties": false
        },
        "description": "规则书实体列表。"
      }
    },
    "required": [
      "items"
    ],
    "description": "规则书搜索结果。",
    "additionalProperties": false
  }
}
