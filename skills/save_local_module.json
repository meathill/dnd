{
  "name": "save_local_module",
  "version": 1,
  "title": "保存模组到本地文件",
  "description": "把结构化模组写入工作区 `data/modules`。",
  "group": "record",
  "executionMode": "native",
  "whenToUse": [
    "模组草稿确认后需要落盘时。",
    "AI 生成模组后需要写入工作区文件时。"
  ],
  "forbidden": [
    "只在自然语言里声称已保存，但没有真正写入文件。"
  ],
  "inputSchema": {
    "type": "object",
    "properties": {
      "module": {
        "type": "object",
        "description": "结构化对象，由宿主根据上下文继续消费。",
        "additionalProperties": true
      },
      "source": {
        "type": "string",
        "enum": [
          "ai",
          "manual",
          "demo"
        ],
        "description": "产物来源，可留空。"
      }
    },
    "required": [
      "module"
    ],
    "description": "模组落盘参数。",
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "filePath": {
        "type": "string",
        "description": "写入的绝对文件路径。"
      },
      "artifact": {
        "type": "object",
        "properties": {
          "schemaVersion": {
            "type": "integer",
            "description": "schema 版本。"
          },
          "kind": {
            "type": "string",
            "const": "module",
            "description": "产物类型。"
          },
          "id": {
            "type": "string",
            "description": "模组 id。"
          },
          "title": {
            "type": "string",
            "description": "模组标题。"
          },
          "rulesetId": {
            "type": "string",
            "description": "规则系统 id。"
          },
          "source": {
            "type": "string",
            "enum": [
              "ai",
              "manual",
              "demo"
            ],
            "description": "产物来源。"
          },
          "createdAt": {
            "type": "string",
            "description": "创建时间。"
          },
          "updatedAt": {
            "type": "string",
            "description": "更新时间。"
          },
          "data": {
            "type": "object",
            "description": "结构化对象，由宿主根据上下文继续消费。",
            "additionalProperties": true
          }
        },
        "required": [
          "schemaVersion",
          "kind",
          "id",
          "title",
          "rulesetId",
          "source",
          "createdAt",
          "updatedAt",
          "data"
        ],
        "description": "写入后的模组文件内容。",
        "additionalProperties": false
      }
    },
    "required": [
      "filePath",
      "artifact"
    ],
    "description": "模组落盘结果。",
    "additionalProperties": false
  }
}
