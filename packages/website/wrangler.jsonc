{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dndcoc",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dnd",
      "database_id": "cb6c1f60-7344-4635-a1a5-c2a88abf3094"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "r2_buckets": [
    {
      "binding": "ASSETS_BUCKET",
      "bucket_name": "dnd"
    },
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "site-cache"
    }
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "dndcoc"
    }
  ],
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  "vars": {
    "NEXT_PUBLIC_APP_BASE_URL": "https://muirpg.meathill.com",
    "NEXT_PUBLIC_ASSET_BASE_URL": "https://i.muirpg.meathill.com",
    "NEXT_PUBLIC_AUTH_COOKIE_DOMAIN": ".muirpg.meathill.com",
    "GAME_RUNTIME": "opencode",
    "GAME_LLM_MODEL": "mimo-v2.5-pro",
    "NEXT_PUBLIC_LLM_PROXY_UPSTREAM_BASE_URL": "https://token-plan-sgp.xiaomimimo.com",
    "NEXT_PUBLIC_LLM_PROXY_ALLOWED_MODELS": "mimo-v2.5-pro",
    "ADMIN_EMAILS": "meathill@gmail.com",
    "OPENCODE_AGENT_BASE_URL": "https://opencode.muirpg.meathill.com"
  }
}
