# 本地 next dev 用：复制为 .env.local（Next.js 自动加载）
# 不要 commit 真实 token

# 应用基础 URL（authCookieDomain 留空即可，next dev 用 localhost 默认）
NEXT_PUBLIC_APP_BASE_URL=http://127.0.0.1:3090

# 后台权限
ADMIN_EMAILS=meathill@gmail.com

# 接本地 agent-server（与 packages/agent-server/.env 的 AGENT_SERVER_TOKEN 必须一致）
OPENCODE_AGENT_BASE_URL=http://127.0.0.1:4180
OPENCODE_AGENT_TOKEN=dev-token

# better-auth 本地用随便填一个长字符串
BETTER_AUTH_SECRET=local-dev-secret-do-not-use-in-prod

# 本地 SQLite 位置（默认 .local/website.sqlite，留空即可）
# DATABASE_URL=
