{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "muirpg-play",
  "account_id": "fdc63eeea83ae8f5234357308b9a638b",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  "r2_buckets": [
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "site-cache"
    }
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "muirpg-play"
    },
    {
      "binding": "WEBSITE",
      "service": "dndcoc"
    }
  ],
  "vars": {
    "NEXT_PUBLIC_PLAY_BASE_URL": "https://play.muirpg.meathill.com",
    "NEXT_PUBLIC_WEBSITE_BASE_URL": "https://muirpg.meathill.com",
    "NEXT_PUBLIC_PLAY_RUNTIME": "opencode",
    "NEXT_PUBLIC_PLAY_LLM_MODEL": "mimo-v2.5-pro"
  }
}
