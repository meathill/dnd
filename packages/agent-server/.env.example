# 本地开发：复制为 .env 即可
# 生产部署用 scripts/setup-vps.sh 生成的 .env，不要把这份样本写到生产机

AGENT_SERVER_TOKEN=dev-token
OPENCODE_SERVER_PASSWORD=dev-password
OPENCODE_MODE=stub
OPENCODE_BASE_URL=http://127.0.0.1:4096
PORT=4180
HOSTNAME=127.0.0.1

# 本地路径（仓库根下的 skills/ 与 packages/agent-server/.workspace/）
AGENT_WORKSPACE_ROOT=./.workspace
AGENT_SKILLS_DIR=../../skills

# stub 模式下不用填，真的接 opencode 才需要
LLM_PROXY_UPSTREAM_BASE_URL=https://token-plan-sgp.xiaomimimo.com
LLM_PROXY_UPSTREAM_API_KEY=
OPENCODE_DEFAULT_MODEL=mimo-v2.5-pro
